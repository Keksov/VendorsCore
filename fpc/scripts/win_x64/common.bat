@echo off

for %%I in ("%~dp0..\..") do set "VENDOR_ROOT=%%~fI"
for %%I in ("%~dp0..") do set "SCRIPT_ROOT=%%~fI"
set "DOWNLOADS_DIR=%VENDOR_ROOT%\downloads"
set "TOOLS_CACHE_DIR=%DOWNLOADS_DIR%\tools"
set "BOOTSTRAP_CACHE_DIR=%DOWNLOADS_DIR%\bootstrap"
set "RELEASE_CACHE_DIR=%DOWNLOADS_DIR%\releases"
set "SOURCES_DIR=%VENDOR_ROOT%\sources"
set "WORK_DIR=%VENDOR_ROOT%\work"
set "BUILD_TEMP_DIR=%VENDOR_ROOT%\build-temp"
set "BOOTSTRAP_INSTALL_DIR=%VENDOR_ROOT%\bootstrap-install"
set "FPC_BIN_TARGET_DIR=%VENDOR_ROOT%\fpc-main"
set "README_FILE=%VENDOR_ROOT%\README.md"
set "ROOT_GITIGNORE=%VENDOR_ROOT%\.gitignore"
set "SCRIPT_GITIGNORE=%SCRIPT_ROOT%\.gitignore"

set "FPC_GIT_HTTPS_URL=https://gitlab.com/freepascal.org/fpc/source.git"
set "FPC_BOOTSTRAP_SOURCE_REF=release_3_2_2"
set "FPC_BOOTSTRAP_SOURCE_DIR=%SOURCES_DIR%\3.2.2"
set "FPC_MAIN_SOURCE_REF=main"
set "FPC_MAIN_SOURCE_DIR=%SOURCES_DIR%\main"

if not defined RELEASE_REPO set "RELEASE_REPO=Keksov/VendorsCore"
set "RELEASE_DOWNLOAD_BASE_URL=https://github.com/%RELEASE_REPO%/releases/download"
if not defined FPC_BOOTSTRAP_RELEASE_TAG set "FPC_BOOTSTRAP_RELEASE_TAG=fpc-bootstrap"
if not defined FPC_MAIN_RELEASE_REF set "FPC_MAIN_RELEASE_REF=latest"
if not defined HTTP_RETRY_ATTEMPTS set "HTTP_RETRY_ATTEMPTS=5"
if not defined HTTP_RETRY_DELAY_SECONDS set "HTTP_RETRY_DELAY_SECONDS=5"

set "FPC_BOOTSTRAP_ASSET_NAME=fpc-3.2.2.win32.and.win64.exe"
set "FPC_BOOTSTRAP_INSTALLER_PATH=%BOOTSTRAP_CACHE_DIR%\%FPC_BOOTSTRAP_ASSET_NAME%"
set "FPC_BOOTSTRAP_DIGEST_FILE=%BOOTSTRAP_CACHE_DIR%\%FPC_BOOTSTRAP_ASSET_NAME%.digest"
set "FPC_BOOTSTRAP_BIN_DIR=%BOOTSTRAP_INSTALL_DIR%\bin\i386-win32"
set "FPC_BOOTSTRAP_PPCROSSX64_EXE=%FPC_BOOTSTRAP_BIN_DIR%\ppcrossx64.exe"
set "FPC_BOOTSTRAP_FPC_EXE=%FPC_BOOTSTRAP_BIN_DIR%\fpc.exe"
set "FPC_BOOTSTRAP_PPC386_EXE=%FPC_BOOTSTRAP_BIN_DIR%\ppc386.exe"

set "FPC_TARGET_CPU=x86_64"
set "FPC_TARGET_OS=win64"
set "FPC_TARGET_SUFFIX=%FPC_TARGET_CPU%-%FPC_TARGET_OS%"
set "FPC_MAIN_STAGE_DIR=%BUILD_TEMP_DIR%\fpc-main-stage"
set "FPC_MAIN_BIN_DIR=%FPC_BIN_TARGET_DIR%\bin\%FPC_TARGET_SUFFIX%"
set "FPC_MAIN_FPC_EXE=%FPC_MAIN_BIN_DIR%\fpc.exe"
set "FPC_MAIN_PPC_EXE=%FPC_MAIN_BIN_DIR%\ppcx64.exe"

set "FPC_MAIN_ARCHIVE_NAME=fpc-main.zip"
if not defined SEVEN_ZIP_EXE set "SEVEN_ZIP_EXE=C:\Program Files\7-Zip\7z.exe"
set "GNUMAKE_FILE_NAME=gnumake-4.4.1-x64.exe"
set "GNUMAKE_ASSET_NAME=%GNUMAKE_FILE_NAME%"
if not defined GNUMAKE_RELEASE_TAG set "GNUMAKE_RELEASE_TAG=%FPC_BOOTSTRAP_RELEASE_TAG%"
set "GNUMAKE_EXE=%TOOLS_CACHE_DIR%\%GNUMAKE_FILE_NAME%"
set "GNUMAKE_DIGEST_FILE=%TOOLS_CACHE_DIR%\%GNUMAKE_FILE_NAME%.digest"